<!DOCTYPE html>
<html lang="fr">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>YTDown Reloaded</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<div class="container">

    <h1>YTDown Reloaded</h1>

    <p class="subtitle">
        Téléchargez une vidéo YouTube au format MP3 ou MP4.
    </p>

    <% if(error){ %>

        <div class="alert <%= error.type %>">

            <%- error.msg %>

        </div>

    <% } %>

    <form method="POST">

        <input
            type="url"
            name="url"
            placeholder="https://youtube.com/watch?v=..."
            required
        >

        <select name="format">

            <option value="mp3">MP3</option>
            <option value="mp4">MP4</option>

        </select>

        <button type="submit">

            Télécharger

        </button>

    </form>

</div>

</body>

</html>